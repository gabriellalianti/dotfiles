#!/bin/bash

source "$CONFIG_DIR/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"
HELPER_DIR="$CONFIG_DIR/helpers"

sketchybar --bar position=top \
    height=40       \
    blur_radius=30  \
    padding_left=4  \
    padding_right=4 \
    color=$BAR_COLOR

# Default values

default=(
padding_left=4
padding_right=4
icon.font="SF Pro:Semibold:12.0"
label.font="SF Pro:Semibold:12.0"
icon.color=$TEXT_COLOR
label.color=$TEXT_COLOR
icon.padding_left=10
icon.padding_right=4
label.padding_left=4
label.padding_right=10
background.color=$ITEM_BG_COLOR
background.border_color=$ACCENT_COLOR
background.border_width=2
background.corner_radius=4
background.height=28
)
sketchybar --default "${default[@]}"

# Left items

source "$ITEM_DIR/aerospace.sh"
source $ITEM_DIR/front_app.sh

# Right items

source $ITEM_DIR/calendar.sh
source $ITEM_DIR/volume.sh
source $ITEM_DIR/battery.sh
source $ITEM_DIR/cpu.sh

for item in calendar volume battery cpu; do
    sketchybar --set "$item" \
        padding_left=0 \
        padding_right=0 \
        background.drawing=off
done

sketchybar --add bracket system_status calendar volume battery cpu \
           --set system_status \
                 background.drawing=on

# Restart the persistent calendar helper whenever sketchybar reloads

pkill -x sketchybar-calendar 2>/dev/null
CALENDAR_HELPER="$HELPER_DIR/sketchybar-calendar"

if [[ -x "$CALENDAR_HELPER" ]]; then
    "$CALENDAR_HELPER" &
else
    echo "Calendar helper has not been compiled." >&2
    echo "Run: make -C \"$HELPER_DIR\"" >&2
fi

# Finalize

sketchybar --update
